{{- $pages := where .Site.RegularPages "Section" "chapters" -}}

<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }} - Chapters Feed</title>
    <link>{{ .Permalink }}</link>
    <generator>Hugo -- gohugo.io</generator>
    {{ with .Site.LanguageCode }}<language>{{.}}</language>{{end}}
    {{ if not .Date.IsZero }}<lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>{{ end }}

    {{- with .OutputFormats.Get "RSS" -}}
    {{ printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}
    {{- end -}}

    {{- range $pages -}}
      {{- /* Extract the chapter number and title using your regex */ -}}
      {{- $chapterNum := "" -}}
      {{- $cleanTitle := .Title -}}
      {{- $matches := findRESubmatch `(?m)^#\s*Chapter\s+(\d+):\s*(.*)$` .RawContent 1 -}}

      {{- if $matches -}}
        {{- $match := index $matches 0 -}}
        {{- $chapterNum = index $match 1 -}}
        {{- $cleanTitle = index $match 2 -}}
      {{- end -}}

    <item>
      <title>{{ .Site.Title }} - Chapter {{ $chapterNum }}</title>

      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>

      <chapter>{{ $chapterNum }}</chapter>

      </item>
    {{- end -}}
  </channel>
</rss>
